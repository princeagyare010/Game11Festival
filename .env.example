# Copy this file to .env and fill in real values before starting the server.
# Never commit the real .env file.

# Port the server listens on
PORT=3000

# "production" enables secure (HTTPS-only) cookies. Use "development" for local http testing.
NODE_ENV=production

# Admin login username
ADMIN_USERNAME=admin

# Admin login password. Use a strong plain-text password for local development.
ADMIN_PASSWORD=

# Long random string used to sign admin session tokens.
# Generate one with:   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long an admin stays logged in
ADMIN_SESSION_HOURS=8
